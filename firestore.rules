rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ───────────────────────────────────────────────────────────────

    function gameData(gameId) {
      return get(/databases/$(database)/documents/games/$(gameId)).data;
    }

    function isLobby(gameId)  { return gameData(gameId).status == 'lobby'; }
    function isActive(gameId) { return gameData(gameId).status == 'active'; }
    function isHost(gameId)   { return request.auth.uid == gameData(gameId).hostId; }
    function isPlayer(gameId) { return exists(/databases/$(database)/documents/games/$(gameId)/players/$(request.auth.uid)); }
    function isBanned(gameId, playerId) {
      return exists(/databases/$(database)/documents/games/$(gameId)/bannedPlayers/$(playerId));
    }
    function playerExists(gameId, playerId) {
      return exists(/databases/$(database)/documents/games/$(gameId)/players/$(playerId));
    }
    function predictionData(gameId, predictionId) {
      return get(/databases/$(database)/documents/games/$(gameId)/predictions/$(predictionId)).data;
    }
    function hostNicknameMatchesPlayer(gameId, nickname) {
      return getAfter(/databases/$(database)/documents/games/$(gameId)/players/$(request.auth.uid)).data.nickname == nickname;
    }

    // ─── Games ─────────────────────────────────────────────────────────────────

    match /games/{gameId} {
      allow read: if resource.data.status == 'lobby' || isPlayer(gameId);

      allow create: if
        request.auth != null
        && request.auth.uid == request.resource.data.hostId
        && request.resource.data.keys().hasAll([
            'code', 'name', 'status', 'hostId', 'hostNickname',
            'gridSize', 'winners', 'createdAt'
          ])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 32
        && request.resource.data.status == 'lobby'
        && request.resource.data.gridSize == 0
        && request.resource.data.hostNickname is string
        && request.resource.data.hostNickname.size() > 0
        && request.resource.data.hostNickname.size() <= 20
        && request.resource.data.winners == [];

      allow update: if
        request.auth != null
        && resource.data.status != 'cancelled'
        && (
          (
            isHost(gameId)
            && resource.data.status == 'lobby'
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'gridSize', 'playerCount'])
            && request.resource.data.status == 'active'
            && request.resource.data.gridSize >= 2
            && request.resource.data.gridSize <= 5
          )
          || (
            // Add winners without finishing (place 1 or 2 awarded, game continues)
            isPlayer(gameId)
            && resource.data.status == 'active'
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['winners'])
            && request.resource.data.winners.size() > resource.data.winners.size()
          )
          || (
            // Add winners and finish game (place 3 or early finish)
            isPlayer(gameId)
            && (resource.data.status == 'active' || resource.data.status == 'finished')
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'winners'])
            && request.resource.data.status == 'finished'
            && request.resource.data.winners.size() > resource.data.winners.size()
          )
          || (
            isHost(gameId)
            && resource.data.status == 'lobby'
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['hostNickname'])
            && request.resource.data.hostNickname is string
            && request.resource.data.hostNickname.size() > 0
            && request.resource.data.hostNickname.size() <= 20
            && hostNicknameMatchesPlayer(gameId, request.resource.data.hostNickname)
          )
          || (
            isHost(gameId)
            && resource.data.status == 'lobby'
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
            && request.resource.data.status == 'cancelled'
          )
        );

      allow delete: if false;

      // ─── Players ─────────────────────────────────────────────────────────────
      match /players/{playerId} {
        allow read: if
          request.auth != null
          && exists(/databases/$(database)/documents/games/$(gameId)/players/$(request.auth.uid));

        allow create: if
          request.auth != null
          && request.auth.uid == playerId
          && isLobby(gameId)
          && !isBanned(gameId, playerId)
          && request.resource.data.keys().hasOnly(['nickname', 'predictionsSubmitted', 'joinedAt', 'pushToken'])
          && request.resource.data.predictionsSubmitted == false
          && request.resource.data.nickname.size() > 0
          && request.resource.data.nickname.size() <= 20;

        allow update: if
          request.auth != null
          && (
            // Player updates their own push token (any game state)
            (request.auth.uid == playerId
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pushToken']))
            // Player updates their own nickname (lobby only)
            || (request.auth.uid == playerId
              && isLobby(gameId)
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['nickname'])
              && request.resource.data.nickname.size() > 0
              && request.resource.data.nickname.size() <= 20)
            // Player submits/retracts their own predictions (lobby only)
            || (isLobby(gameId)
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['predictionsSubmitted'])
              && (
                request.auth.uid == playerId
                || (isHost(gameId) && request.resource.data.predictionsSubmitted == false)
              ))
          );

        allow delete: if
          request.auth != null
          && (
            (request.auth.uid == playerId && isLobby(gameId))
            || (isHost(gameId) && request.auth.uid != playerId && (isLobby(gameId) || isActive(gameId)))
          );
      }

      // ─── Predictions ─────────────────────────────────────────────────────────

      match /predictions/{predictionId} {
        allow read: if isPlayer(gameId);

        allow create: if
          request.auth != null
          && isPlayer(gameId)
          && request.auth.uid == request.resource.data.authorId
          && isLobby(gameId)
          && request.resource.data.keys().hasAll(['authorId', 'subjectId', 'text', 'createdAt'])
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 50
          && request.resource.data.authorId != request.resource.data.subjectId
          && playerExists(gameId, request.resource.data.subjectId);

        allow update: if
          request.auth != null
          && isLobby(gameId)
          && isPlayer(gameId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions']);

        allow delete: if
          request.auth != null
          && (request.auth.uid == resource.data.authorId || request.auth.uid == resource.data.subjectId || isHost(gameId))
          && isLobby(gameId);
      }

      // ─── Cards ───────────────────────────────────────────────────────────────

      match /cards/{playerId} {
        allow read: if isPlayer(gameId);

        allow create: if
          request.auth != null
          && isHost(gameId)
          && isLobby(gameId)
          && request.resource.data.keys().hasAll(['grid'])
          && request.resource.data.grid is list;

        allow update: if false;
        allow delete: if false;
      }

      // ─── Marks ───────────────────────────────────────────────────────────────

      match /marks/{predictionId} {
        allow read: if isPlayer(gameId);

        allow create: if
          request.auth != null
          && isPlayer(gameId)
          && request.auth.uid == request.resource.data.markedBy
          && isActive(gameId)
          && request.resource.data.keys().hasAll(['markedBy', 'markedByNickname', 'markedAt'])
          && predictionData(gameId, predictionId).subjectId != request.auth.uid;

        allow update: if false;
        allow delete: if false;
      }

      // ─── Reports ─────────────────────────────────────────────────────────────

      match /reports/{reportId} {
        allow create: if
          request.auth != null
          && isPlayer(gameId)
          && request.resource.data.keys().hasAll([
            'targetType',
            'targetId',
            'reason',
            'reporterId',
            'status',
            'createdAt'
          ])
          && request.resource.data.reporterId == request.auth.uid
          && request.resource.data.status == 'open'
          && request.resource.data.targetType in ['prediction', 'player']
          && request.resource.data.reason in ['harassment', 'sexual_content', 'hate_speech', 'spam', 'other'];

        allow read, update, delete: if false;
      }

      // ─── Banned players ──────────────────────────────────────────────────────

      match /bannedPlayers/{playerId} {
        allow read: if
          request.auth != null
          && (request.auth.uid == playerId || isHost(gameId));

        allow create: if
          request.auth != null
          && isHost(gameId)
          && request.resource.data.keys().hasOnly(['bannedAt', 'bannedBy'])
          && request.resource.data.bannedBy == request.auth.uid;

        allow update: if false;

        allow delete: if
          request.auth != null
          && isHost(gameId);
      }
    }
  }
}
