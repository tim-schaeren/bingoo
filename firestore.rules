rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ───────────────────────────────────────────────────────────────

    function gameData(gameId) {
      return get(/databases/$(database)/documents/games/$(gameId)).data;
    }

    function isLobby(gameId)  { return gameData(gameId).status == 'lobby'; }
    function isActive(gameId) { return gameData(gameId).status == 'active'; }
    function isHost(gameId)   { return request.auth.uid == gameData(gameId).hostId; }

    // ─── Games ─────────────────────────────────────────────────────────────────

    match /games/{gameId} {
      allow read: if true;

      allow create: if
        request.auth != null
        && request.auth.uid == request.resource.data.hostId
        && request.resource.data.keys().hasAll([
            'code', 'status', 'hostId', 'hostNickname',
            'gridSize', 'winnerId', 'winnerNickname', 'createdAt'
          ])
        && request.resource.data.status == 'lobby'
        && request.resource.data.gridSize == 0
        && request.resource.data.winnerId == null;

      allow update: if
        request.auth != null
        && resource.data.status != 'finished'
        && (
          (request.resource.data.status == 'active' && isHost(gameId))
          || (request.resource.data.status == 'finished'
              && request.auth.uid == request.resource.data.winnerId)
        );

      allow delete: if false;

      // ─── Players ─────────────────────────────────────────────────────────────

      match /players/{playerId} {
        allow read: if true;

        allow create: if
          request.auth != null
          && request.auth.uid == playerId
          && isLobby(gameId)
          && request.resource.data.keys().hasAll(['nickname', 'predictionsSubmitted', 'joinedAt'])
          && request.resource.data.predictionsSubmitted == false
          && request.resource.data.nickname.size() > 0
          && request.resource.data.nickname.size() <= 20;

        allow update: if
          request.auth != null
          && request.auth.uid == playerId
          && isLobby(gameId)
          && request.resource.data.predictionsSubmitted == true
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['predictionsSubmitted']);

        allow delete: if false;
      }

      // ─── Predictions ─────────────────────────────────────────────────────────

      match /predictions/{predictionId} {
        allow read: if true;

        allow create: if
          request.auth != null
          && request.auth.uid == request.resource.data.authorId
          && isLobby(gameId)
          && request.resource.data.keys().hasAll(['authorId', 'subjectId', 'text', 'createdAt'])
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 120
          && request.resource.data.authorId != request.resource.data.subjectId;

        allow update: if false;
        allow delete: if false;
      }

      // ─── Cards ───────────────────────────────────────────────────────────────

      match /cards/{playerId} {
        allow read: if true;

        allow create: if
          request.auth != null
          && isHost(gameId)
          && isLobby(gameId)
          && request.resource.data.keys().hasAll(['grid'])
          && request.resource.data.grid is list;

        allow update: if false;
        allow delete: if false;
      }

      // ─── Marks ───────────────────────────────────────────────────────────────

      match /marks/{predictionId} {
        allow read: if true;

        allow create: if
          request.auth != null
          && request.auth.uid == request.resource.data.markedBy
          && isActive(gameId)
          && request.resource.data.keys().hasAll(['markedBy', 'markedByNickname', 'markedAt']);

        allow update: if false;
        allow delete: if false;
      }
    }
  }
}
